# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=your_very_secure_random_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# SendGrid Email Configuration
SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
SENDGRID_FROM_EMAIL=noreply@dotvests.com
FRONTEND_URL=http://localhost:3000

# Admin Notifications Configuration
# Comma-separated list of admin emails to receive contact form notifications
ADMIN_EMAILS=contact@dotvests.com,admin@dotvests.com,support@dotvests.com
ADMIN_DASHBOARD_URL=http://localhost:3000/admin

# Paystack Payment Configuration
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here

# ZetaChain Blockchain Configuration
PRIVATE_KEY=0x_your_wallet_private_key_here
PLATFORM_WALLET=0x_platform_wallet_address_here
DTV_CONTRACT=0x_dtv_token_contract_address
TEL_CONTRACT=0x_tel_token_contract_address
ORB_CONTRACT=0x_orb_token_contract_address
CEM_CONTRACT=0x_cem_token_contract_address

# Database
# Note: SQLite database will be auto-created at db/dotvests.db on first run
# No configuration needed unless you want to change the path
